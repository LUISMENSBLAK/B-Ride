NODE_ENV=development
PORT=5001

# Database
MONGODB_URI=mongodb://localhost:27017/bride_db

# Authentication
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64

# Email — Get your key at https://resend.com
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev
FROM_NAME=B-Ride

# SMS — Get your credentials at https://dashboard.nexmo.com
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM=BRide

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CONEKTA_API_KEY=

# Firebase
# Download your service account JSON from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Frontend (used for password reset emails)
FRONTEND_URL=http://localhost:8081

# CORS — comma-separated list of allowed origins for both REST and WebSocket
# Example: http://localhost:8081,https://yourapp.com
CORS_ORIGIN=http://localhost:8081

# Currency rates (fallback — replace with live API in production)
RATE_MXN=17.5
RATE_EUR=0.92

# CDN & Monitoring
CDN_URL=
SENTRY_DSN=
