# ╔══════════════════════════════════════════════════════════════╗
# ║              B-RIDE — Variables de Entorno                  ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── OBLIGATORIAS (el servidor NO arrancará sin estas) ────────
MONGODB_URI=mongodb://localhost:27017/bride
JWT_SECRET=your_jwt_secret_here_change_in_production
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key_here

# ─── RECOMENDADAS ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:8081,http://localhost:19006
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# CORRECCIÓN 5: URLs de retorno del onboarding Stripe (deep links Expo)
STRIPE_ONBOARDING_REFRESH_URL=bride://driver/onboarding/refresh
STRIPE_ONBOARDING_RETURN_URL=bride://driver/onboarding/return

# CORRECCIÓN 6: País ISO de operación de Stripe Connect (ej: ES, MX, CO, US)
STRIPE_CONNECT_COUNTRY=US

# CORRECCIÓN 6: Moneda ISO para cobros (ej: eur, mxn, cop, usd)
STRIPE_CURRENCY=usd

# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# SENTRY_DSN=https://your-dsn@sentry.io/project-id

# ─── OPCIONALES ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# CDN_URL=https://cdn.b-ride.com
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
