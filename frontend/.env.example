#
# En desarrollo local, crea un archivo .env con estos valores.
# En producción (EAS Build), configúralas con:
#   eas secret:create --name EXPO_PUBLIC_API_URL --value https://tu-backend.railway.app/api
#
EXPO_PUBLIC_API_URL=http://localhost:5000/api
EXPO_PUBLIC_SOCKET_URL=http://localhost:5000
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXX
