{
  "expo": {
    "name": "B-Ride",
    "slug": "b-ride",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "bride",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bride.app",
      "config": {
        "googleMapsApiKey": "AIzaSyBZCGxCJOhOIa3KrlAo0IeLHBbyARjdLLI"
      },
      "googleServicesFile": "./GoogleService-Info.plist",
      "entitlements": {
        "com.apple.developer.location.push": true
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "B-Ride necesita tu ubicación para mostrarte conductores cercanos y calcular rutas.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "B-Ride usa tu ubicación en segundo plano para trackear tu viaje en tiempo real.",
        "NSLocationAlwaysUsageDescription": "B-Ride usa tu ubicación en segundo plano para trackear tu viaje en tiempo real.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bride.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBZCGxCJOhOIa3KrlAo0IeLHBbyARjdLLI"
        }
      },
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "B-Ride usa tu ubicación para conectarte con conductores cercanos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#276EF1"
        }
      ],
      "expo-localization",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.bride.app",
          "enableGooglePay": true
        }
      ],
      [
        "@react-native-google-signin/google-signin"
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d04032a9-0209-4b64-869e-492ebf5e0d51"
      }
    }
  }
}
